# ─────────────────────────────────────────────────────────────────────────────
# TrackCodex — Production Environment Variables Template (AWS)
# Copy to /opt/trackcodex/.env.prod on your EC2 instance
# NEVER commit this file — it contains secrets!
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (AWS RDS PostgreSQL) ───────────────────────────────────────────
# Get this from: AWS Console → RDS → your instance → Connectivity & security
DATABASE_URL="postgresql://<RDS_USER>:<RDS_PASSWORD>@trackcodex-db.cnie88q6ughh.ap-south-1.rds.amazonaws.com:5432/trackcodex_db?sslmode=require"

# ─── Firebase Auth (same as before) ──────────────────────────────────────────
FIREBASE_PROJECT_ID=trackcodex-38862
FIREBASE_DATABASE_SECRET=<YOUR_FIREBASE_DATABASE_SECRET>
# FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account",...}'

# ─── JWT & Cookies ────────────────────────────────────────────────────────────
JWT_SECRET="<GENERATE_A_STRONG_SECRET_MIN_32_CHARS>"
JWT_EXPIRES_IN="7d"
COOKIE_SECRET="<GENERATE_ANOTHER_STRONG_SECRET_MIN_32_CHARS>"

# ─── OAuth ───────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="<YOUR_GOOGLE_CLIENT_ID>"
GOOGLE_CLIENT_SECRET="<YOUR_GOOGLE_CLIENT_SECRET>"
GOOGLE_REDIRECT_URI="https://trackcodex.com/auth/callback/google"

GITHUB_CLIENT_ID="<YOUR_GITHUB_CLIENT_ID>"
GITHUB_CLIENT_SECRET="<YOUR_GITHUB_CLIENT_SECRET>"
GITHUB_REDIRECT_URI="https://trackcodex.com/auth/callback/github"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
FRONTEND_URL="https://trackcodex.com"
# Your EC2 public domain or IP (used for CORS whitelist):
AWS_BACKEND_URL="http://65.2.146.75"   # Update to https://api.trackcodex.com once domain + SSL is set up
# Optional: If using a subdomain wildcard for CORS (e.g. ".trackcodex.com")
# AWS_EC2_DOMAIN=".trackcodex.com"

# ─── AWS OpenSearch (replaces local Elasticsearch) ───────────────────────────
# Get this from: AWS Console → OpenSearch → your domain → Endpoint
ELASTICSEARCH_URL="https://<YOUR_OPENSEARCH_ENDPOINT>.ap-south-1.es.amazonaws.com"   # Fill in after OpenSearch is created

# ─── Kafka (disabled — using direct writes to OpenSearch) ────────────────────
# KAFKA_BROKER_URL=  # Leave blank; outbox worker will skip Kafka if not set

# ─── Other Services ──────────────────────────────────────────────────────────
RESEND_API_KEY="<YOUR_RESEND_API_KEY>"
GEMINI_API_KEY="<YOUR_GEMINI_API_KEY>"
ENCRYPTION_KEY="<GENERATE_A_UUID_OR_32_CHAR_SECRET>"

# ─── Gitea ───────────────────────────────────────────────────────────────────
GITEA_URL="http://localhost:3000"
GITEA_API_TOKEN="<YOUR_GITEA_TOKEN>"
